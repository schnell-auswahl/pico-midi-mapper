#include <Arduino.h>

// EINFACHER TEST - Nur LED blinken lassen
// Später kannst du zu den kompletten MIDI-Funktionen wechseln

const int LED_PIN = 25;  // Onboard LED am Pico

void setup() {
    // Serielle Konsole für Debugging
    Serial.begin(115200);
    delay(2000);  // Warte 2 Sekunden
    
    Serial.println("\n=================================");
    Serial.println("  Raspberry Pi Pico - LED Test");
    Serial.println("=================================");
    Serial.println("Die onboard LED sollte blinken!");
    Serial.println("Wenn du das siehst, funktioniert");
    Serial.println("der Upload perfekt!\n");
    
    // LED-Pin als Ausgang konfigurieren
    pinMode(LED_PIN, OUTPUT);
    Serial.println("LED-Test gestartet...\n");
}

void loop() {
    // LED einschalten
    digitalWrite(LED_PIN, HIGH);
    Serial.println("LED AN");
    delay(500);  // 500ms warten
    
    // LED ausschalten
    digitalWrite(LED_PIN, LOW);
    Serial.println("LED AUS");
    delay(500);  // 500ms warten
}
