#ifndef SOLENOID_DRIVER_H
#define SOLENOID_DRIVER_H

#include <Arduino.h>
#include "config.h"

class SolenoidDriver {
public:
    SolenoidDriver();
    
    // Initialisierung aller Solenoid-Pins
    void begin();
    
    // Solenoid aktivieren mit optionaler Velocity (0-127)
    void trigger(uint8_t solenoidIndex, uint8_t velocity = 127);
    
    // Muss regelmäßig in der loop() aufgerufen werden
    void update();
    
    // Alle Solenoids sofort deaktivieren (Notfall)
    void allOff();
    
    // Test-Sequenz: alle Solenoids nacheinander testen
    void testSequence();

private:
    struct SolenoidState {
        uint32_t offTime;    // Zeitpunkt, zu dem Solenoid deaktiviert werden soll
        bool active;         // Ist der Solenoid aktuell aktiv?
    };
    
    SolenoidState states[NUM_SOLENOIDS];
    
    // Velocity in PWM-Duty-Cycle konvertieren (0-255)
    uint8_t velocityToDutyCycle(uint8_t velocity);
};

#endif // SOLENOID_DRIVER_H
