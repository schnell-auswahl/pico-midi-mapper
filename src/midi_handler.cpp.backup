#include "midi_handler.h"

// Statischer Pointer für Callback-Zugriff
SolenoidDriver* MidiHandler::solenoidDriver = nullptr;

MidiHandler::MidiHandler(SolenoidDriver* driver) {
    solenoidDriver = driver;
}

void MidiHandler::begin() {
    #ifdef USB_MIDI_ENABLED
        // USB MIDI initialisieren
        MIDI_USB.begin(MIDI_CHANNEL_OMNI);  // Empfange auf allen Kanälen
        MIDI_USB.setHandleNoteOn(handleNoteOn);
        MIDI_USB.setHandleNoteOff(handleNoteOff);
        Serial.println("MidiHandler: USB MIDI initialized");
    #endif
    
    #ifdef UART_MIDI_ENABLED
        // UART MIDI initialisieren (Serial1 auf GP0/GP1)
        Serial1.setRX(UART_MIDI_RX_PIN);
        Serial1.setTX(UART_MIDI_TX_PIN);
        MIDI_UART.begin(MIDI_CHANNEL_OMNI);
        MIDI_UART.setHandleNoteOn(handleNoteOn);
        MIDI_UART.setHandleNoteOff(handleNoteOff);
        Serial.println("MidiHandler: UART MIDI initialized on pins " + 
                      String(UART_MIDI_RX_PIN) + "/" + String(UART_MIDI_TX_PIN));
    #endif
    
    Serial.println("MidiHandler: Listening on MIDI channel " + String(MIDI_CHANNEL) + " (and all channels)");
}

void MidiHandler::update() {
    // Beide MIDI-Interfaces verarbeiten
    #ifdef USB_MIDI_ENABLED
        MIDI_USB.read();
    #endif
    
    #ifdef UART_MIDI_ENABLED
        MIDI_UART.read();
    #endif
}

void MidiHandler::handleNoteOn(byte channel, byte note, byte velocity) {
    // Debug-Ausgabe
    Serial.print("MIDI Note ON: Ch:");
    Serial.print(channel);
    Serial.print(" Note:");
    Serial.print(note);
    Serial.print(" Vel:");
    Serial.println(velocity);
    
    // Velocity 0 wird als Note Off behandelt
    if (velocity == 0) {
        handleNoteOff(channel, note, velocity);
        return;
    }
    
    // Finde den entsprechenden Solenoid
    int8_t solenoidIndex = noteToSolenoid(note);
    
    if (solenoidIndex >= 0) {
        // Triggere den Solenoid
        if (solenoidDriver) {
            solenoidDriver->trigger(solenoidIndex, velocity);
        }
    } else {
        // Note ist nicht gemappt
        Serial.println("  -> Note not mapped to any solenoid");
    }
}

void MidiHandler::handleNoteOff(byte channel, byte note, byte velocity) {
    // Note Off ist bei Solenoids nicht relevant, da sie automatisch 
    // nach SOLENOID_PULSE_MS deaktiviert werden
    // Könnte für Debug-Zwecke verwendet werden
    
    // Serial.print("MIDI Note OFF: Ch:");
    // Serial.print(channel);
    // Serial.print(" Note:");
    // Serial.println(note);
}

int8_t MidiHandler::noteToSolenoid(uint8_t note) {
    // Suche die Note in der Mapping-Tabelle
    for (int i = 0; i < NUM_SOLENOIDS; i++) {
        if (MIDI_NOTE_MAP[i] == note) {
            return i;
        }
    }
    
    // Note nicht gefunden
    return -1;
}
